# Copy this file to .env.local or set these variables in Vercel Project Settings.
# Do NOT commit a file containing real secret keys.

# Supabase project URL (found in Supabase project settings)
SUPABASE_URL=

# Supabase service role key (server-side only). Use only on server and in Vercel env vars.
# IMPORTANT: do NOT commit real secret keys. Replace the values below locally only.
SUPABASE_SERVICE_ROLE_KEY=

# Optional client anon key (if you plan to use client-side Supabase calls)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: if you use a different env name for the service key, fill it here
SUPABASE_KEY=

# Direct Postgres connection string (optional - used for psql or migrations)
# Replace [YOUR-PASSWORD] with your actual DB password. Keep this secret and do not commit.
DATABASE_URL=postgresql://postgres:MyPassword_MotoLog@db.avehtcujvmjnafavozpp.supabase.co:5432/postgres

# Notes:
# - Set `SUPABASE_URL` and `SUPABASE_SERVICE_ROLE_KEY` in Vercel Project → Settings → Environment Variables for production/preview.
# - `DATABASE_URL` is useful for running `psql` or migration tools locally; prefer using the Supabase SQL editor for quick setup.
# - The server code in `api/index.js` detects `SUPABASE_URL` + service key to enable Supabase mode.
